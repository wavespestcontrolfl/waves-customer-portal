{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wavespestcontrol.com/schemas/blog-post.schema.json",
  "title": "Waves Blog Post Frontmatter",
  "description": "Frontmatter contract for Astro blog posts on the Waves spoke fleet. Admin portal validates drafts against this before publish.",
  "frontmatter": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "properties": {
      "title": {
        "type": "string",
        "minLength": 1
      },
      "slug": {
        "type": "string",
        "pattern": "^\\/[a-z0-9-]+(\\/[a-z0-9-]+)*\\/$"
      },
      "meta_description": {
        "type": "string",
        "minLength": 115,
        "maxLength": 160
      },
      "primary_keyword": {
        "type": "string",
        "minLength": 1
      },
      "secondary_keywords": {
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "category": {
        "type": "string",
        "enum": [
          "pest-control",
          "lawn-care",
          "termite",
          "mosquito",
          "tree-shrub",
          "seasonal"
        ]
      },
      "post_type": {
        "type": "string",
        "enum": [
          "diagnostic",
          "seasonal",
          "by-grass-type",
          "protocol",
          "cost",
          "comparison",
          "case-study",
          "location",
          "decision"
        ]
      },
      "service_areas_tag": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "Bradenton",
            "Lakewood Ranch",
            "Sarasota",
            "Venice",
            "North Port",
            "Palmetto",
            "Parrish",
            "Port Charlotte"
          ]
        }
      },
      "related_waveguard_tier": {
        "type": "string",
        "enum": [
          "Bronze",
          "Silver",
          "Gold",
          "Platinum"
        ]
      },
      "related_services": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "hub_link": {
        "type": "string"
      },
      "spoke_links": {
        "maxItems": 20,
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "author": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "type": "string",
            "minLength": 1
          },
          "fdacs_license": {
            "type": "string",
            "pattern": "^JB\\d{4,}$"
          },
          "years_swfl": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "bio_url": {
            "type": "string",
            "pattern": "^\\/about\\/authors\\/[a-z0-9-]+$"
          }
        },
        "required": [
          "name",
          "role",
          "bio_url"
        ],
        "additionalProperties": false
      },
      "technically_reviewed_by": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "credential": {
            "type": "string",
            "minLength": 1
          },
          "fdacs_license": {
            "type": "string",
            "pattern": "^JB\\d{4,}$"
          },
          "bio_url": {
            "type": "string",
            "pattern": "^\\/about\\/authors\\/[a-z0-9-]+$"
          }
        },
        "required": [
          "name",
          "credential",
          "bio_url"
        ],
        "additionalProperties": false
      },
      "fact_checked_by": {
        "type": "string",
        "minLength": 1
      },
      "published": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "updated": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "technically_reviewed": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "fact_checked": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "review_cadence": {
        "type": "string",
        "enum": [
          "monthly",
          "quarterly",
          "annually"
        ]
      },
      "reading_time_min": {
        "type": "integer",
        "minimum": 1,
        "maximum": 9007199254740991
      },
      "hero_image": {
        "type": "object",
        "properties": {
          "src": {
            "type": "string",
            "pattern": "^\\/.+\\.(webp|jpg|jpeg|png|avif)$"
          },
          "alt": {
            "type": "string",
            "minLength": 1
          },
          "caption": {
            "type": "string"
          },
          "credit": {
            "type": "string"
          }
        },
        "required": [
          "src",
          "alt"
        ],
        "additionalProperties": false
      },
      "og_image": {
        "type": "string",
        "pattern": "^\\/.+\\.(webp|jpg|jpeg|png|avif)$"
      },
      "canonical": {
        "type": "string",
        "format": "uri"
      },
      "schema_types": {
        "minItems": 1,
        "type": "array",
        "items": {
          "type": "string",
          "enum": [
            "Article",
            "FAQPage",
            "BreadcrumbList",
            "HowTo",
            "Service",
            "Review"
          ]
        }
      },
      "disclosure": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "pricing-transparency",
              "service-area-limits",
              "regulatory",
              "none"
            ]
          },
          "text": {
            "type": "string"
          }
        },
        "required": [
          "type"
        ],
        "additionalProperties": false
      },
      "tracking": {
        "type": "object",
        "properties": {
          "number_key": {
            "type": "string"
          },
          "domains": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "robots": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "required": [
      "title",
      "slug",
      "meta_description",
      "primary_keyword",
      "secondary_keywords",
      "category",
      "post_type",
      "service_areas_tag",
      "related_services",
      "spoke_links",
      "author",
      "technically_reviewed_by",
      "fact_checked_by",
      "published",
      "updated",
      "technically_reviewed",
      "fact_checked",
      "review_cadence",
      "reading_time_min",
      "hero_image",
      "og_image",
      "canonical",
      "schema_types",
      "disclosure"
    ],
    "additionalProperties": false
  },
  "postTypeRequirements": {
    "decision": {
      "required": [
        "BottomLineBox",
        "ComparisonTable",
        "HonestRejection"
      ]
    },
    "diagnostic": {
      "required": [
        "AnnotatedDiagnosticPhoto",
        "PestDiagnosticTree"
      ],
      "recommended": [
        "CaseStudy"
      ]
    },
    "seasonal": {
      "required": [
        "SeasonalCalendar",
        "ContentUpgrade"
      ]
    },
    "protocol": {
      "required": [
        "DataCallout"
      ],
      "recommended": [
        "HonestRejection"
      ]
    },
    "cost": {
      "required": [
        "WaveGuardLadder",
        "DisclosureBlock",
        "ComparisonTable"
      ]
    },
    "comparison": {
      "required": [
        "ComparisonTable",
        "HonestRejection"
      ]
    },
    "case-study": {
      "required": [
        "CaseStudy"
      ]
    },
    "location": {
      "required": []
    },
    "by-grass-type": {
      "required": [
        "GrassTypeSection"
      ]
    }
  }
}
