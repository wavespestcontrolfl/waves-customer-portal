{
  "name": "waves-customer-portal",
  "version": "1.0.0",
  "description": "Customer portal for Waves Pest Control — Twilio SMS + Stripe Payments",
  "private": true,
  "workspaces": [
    "server",
    "client",
    "packages/*"
  ],
  "scripts": {
    "predev": "npm run db:migrate",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "prebuild": "npm run verify:blog-schema && npm run check:portal-brand",
    "build": "cd client && npm run build",
    "check:portal-brand": "node scripts/check-portal-brand.js",
    "prestart": "npm run verify:blog-schema",
    "start": "node server/index.js",
    "db:migrate": "cd server && npx knex migrate:latest",
    "db:rollback": "cd server && npx knex migrate:rollback",
    "db:seed": "cd server && npx knex seed:run",
    "test": "cd server && npm test",
    "test:contracts": "node server/contract-tests/index.js",
    "test:contracts:list": "node server/contract-tests/index.js --list",
    "models:check": "node scripts/check-models.js",
    "seed:pricing": "node scripts/seed-local-pricing.js",
    "twilio:flow:export": "node scripts/twilio/export-studio-flow.js",
    "twilio:flow:verify": "node scripts/twilio/verify-studio-flow-contract.js",
    "twilio:inbound:audit": "node scripts/twilio/audit-inbound-routing.js",
    "twilio:inbound:set-url": "node scripts/twilio/set-inbound-voice-url.js",
    "smoke:lead-estimate-automation": "node server/scripts/smoke-lead-estimate-automation.js",
    "eval:lawn-diagnostic": "node server/scripts/run-lawn-diagnostic-eval.js",
    "check:lawn-models": "node server/scripts/check-lawn-model-readiness.js",
    "agent:export-fixtures": "node server/scripts/export-agent-decision-fixtures.js",
    "agent:export-reply-fixtures": "node server/scripts/export-reply-training-fixtures.js",
    "agent:evaluate-fixtures": "node server/scripts/evaluate-agent-decision-fixtures.js",
    "agent:replay-estimate-conversion": "node server/scripts/replay-estimate-conversion-agent.js",
    "eval:call-replay": "node server/scripts/run-call-extraction-replay-eval.js --json",
    "verify:blog-schema": "node packages/blog-schema/scripts/verify-vendor.js",
    "sync:blog-schema": "node packages/blog-schema/scripts/sync-from-astro.js",
    "content:registry:live-status": "node server/scripts/check-content-registry-live-status.js",
    "content:registry:archive-stale": "node server/scripts/archive-stale-blog-rows.js",
    "backlink:sync-strategy-agent": "node scripts/create-backlink-strategy-agent.js",
    "seo:pipeline:run": "node server/scripts/run-seo-pipeline.js",
    "seo:pipeline:worker": "node server/scripts/run-seo-pipeline-worker.js",
    "audit:waveguard-materials": "node server/scripts/audit-waveguard-protocol-material-costs.js",
    "prepare": "git config core.hooksPath scripts/hooks 2>/dev/null || true",
    "hooks:install": "git config core.hooksPath scripts/hooks"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google-analytics/data": "^5.2.1",
    "@sentry/node": "^10.47.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "archiver": "^7.0.1",
    "csv-parse": "^6.2.1",
    "google-ads-api": "^23.0.0",
    "googleapis": "^171.4.0",
    "imapflow": "^1.2.18",
    "js-yaml": "^4.1.1",
    "nodemailer": "^8.0.4",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "stripe": "^22.0.0",
    "ws": "^8.20.0"
  }
}
