# =============================================================================
# Waves Pest Control — Customer Portal Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================================

# ---- Server ----
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://waves_user:your_password@localhost:5432/waves_portal
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- Authentication ----
JWT_SECRET=replace_with_random_64_char_string_use_openssl_rand_hex_32
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# ---- Twilio (SMS Notifications) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+19415551234
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ---- AWS S3 (Service Photos) ----
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=waves-pest-control-photos
S3_PHOTO_PREFIX=service-photos/

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Logging ----
LOG_LEVEL=info

# ---- Anthropic (AI Assistant, Blog Writer, CSR Coach) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ---- Google API (GSC, GBP) ----
GOOGLE_API_KEY=AIzaxxxxxxxx

# ---- Admin Phone (for escalation alerts) ----
ADAM_PHONE=+19413187612

# ---- WordPress (optional — blog publishing) ----
WORDPRESS_URL=https://wavespestcontrol.com
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=

# =============================================================================
# FEATURE GATES — Human-in-the-loop safety for production
#
# In production (NODE_ENV=production), ALL gates default to OFF.
# In development, all gates are ON by default.
#
# Deployment workflow:
#   1. Deploy to Railway with all gates OFF (don't set any GATE_ vars)
#   2. Check /api/health — confirms all gates show disabled
#   3. Test each integration manually via the admin portal
#   4. Enable gates one at a time in Railway environment variables
#
# =============================================================================
# GATE_TWILIO_SMS=true          # Real SMS to real phone numbers
# GATE_TWILIO_VOICE=true        # Voice call handling + recording
# GATE_AI_ASSISTANT=true        # AI auto-replies to customer SMS
# GATE_AI_BLOG_WRITER=true      # AI content generation
# GATE_CRON_JOBS=true           # All automated cron jobs
# GATE_WEBHOOKS=true            # Inbound Twilio/Stripe/Lead webhooks
# GATE_WORDPRESS_PUBLISH=true   # Publishing posts to WordPress
