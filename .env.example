# =============================================================================
# Waves Pest Control — Customer Portal Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================================

# ---- Server ----
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
WAVES_FDACS_LICENSE=JB351547
VITE_WAVES_FDACS_LICENSE=JB351547

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://waves_user:your_password@localhost:5432/waves_portal
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- Authentication ----
JWT_SECRET=replace_with_random_64_char_string_use_openssl_rand_hex_32
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# ---- Twilio (SMS Notifications) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+19415551234
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ---- Stripe Terminal / Tap to Pay on iPhone ----
# Pre-registered Stripe Terminal location for the iOS Tap to Pay app.
STRIPE_TERMINAL_LOCATION_ID=tml_xxxxxxxxxxxxxx
# HMAC signing secret for short-lived (60s) handoff JWTs minted by
# POST /api/stripe/terminal/handoff. MUST be different from JWT_SECRET so
# that a portal-token leak does not let an attacker mint card_present
# tokens. Generate with: openssl rand -hex 32
TERMINAL_HANDOFF_SECRET=replace_with_openssl_rand_hex_32_output
# Per-tech mint ceiling per rolling hour. Baseline 20 assumes 8–12 normal
# stops/day + retry headroom; 20+ within an hour is alert-worthy. Dev can
# set 100 for easier manual testing. Leave blank to use the default (20).
HANDOFF_MINT_RATE_LIMIT_PER_HOUR=

# ---- Bouncie GPS / Mileage ----
BOUNCIE_CLIENT_ID=your_bouncie_client_id
BOUNCIE_CLIENT_SECRET=your_bouncie_client_secret
BOUNCIE_ACCESS_TOKEN=optional_bootstrap_access_token
BOUNCIE_REFRESH_TOKEN=optional_bootstrap_refresh_token
BOUNCIE_WEBHOOK_SECRET=replace_with_bouncie_webhook_key
BOUNCIE_VEHICLE_IMEI=optional_default_vehicle_imei
BOUNCIE_REDIRECT_URI=https://portal.example.com/api/bouncie/callback
# Optional static OAuth state for manual auth URLs. Prefer /api/bouncie/auth.
BOUNCIE_OAUTH_STATE=

# ---- AWS S3 (Service Photos) ----
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=waves-pest-control-photos
S3_PHOTO_PREFIX=service-photos/

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Logging ----
LOG_LEVEL=info

# ---- Anthropic (AI Assistant, Blog Writer, CSR Coach) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ---- Google API (GSC, GBP) ----
GOOGLE_API_KEY=AIzaxxxxxxxx

# ---- Social Media Automation ----
# Global kill switch. Keep false until platform credentials and dry-run output are verified.
SOCIAL_AUTOMATION_ENABLED=false
SOCIAL_DRY_RUN=true
SOCIAL_FACEBOOK_ENABLED=false
SOCIAL_INSTAGRAM_ENABLED=false
# (LinkedIn is intentionally not wired — no SOCIAL_LINKEDIN_ENABLED flag; the
# publish path hard-disables it as a deliberate scope decision.)
SOCIAL_GBP_ENABLED=false
SOCIAL_RSS_AUTOPUBLISH_ENABLED=false
SOCIAL_SCHEDULED_POSTS_ENABLED=false
SOCIAL_NEWSLETTER_AUTOSHARE_ENABLED=false
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
LINKEDIN_COMPANY_ID=
LINKEDIN_ACCESS_TOKEN=
SOCIAL_MEDIA_CDN_DOMAIN=

# Autonomous Social Studio.
# Set SOCIAL_DRY_RUN=false only when you want real posts to publish.
# SOCIAL_AUTONOMOUS_STUDIO_ENABLED turns the Studio on for manual admin use and
# gates its write endpoints. SOCIAL_AUTONOMOUS_CRON_ENABLED is the SEPARATE
# opt-in for the hourly scheduler to publish automatically — both must be true
# for autonomous posts to run, so enabling manual use alone never auto-posts.
SOCIAL_AUTONOMOUS_STUDIO_ENABLED=false
SOCIAL_AUTONOMOUS_CRON_ENABLED=false
SOCIAL_AUTONOMOUS_MODE=publish
SOCIAL_AUTONOMOUS_INTERVAL_HOURS=24
# linkedin is NOT wired yet (publish path hard-disables it) — leave it out.
SOCIAL_AUTONOMOUS_CHANNELS=gbp,facebook,instagram
SOCIAL_AUTONOMOUS_INCLUDE_REVIEWS=true

# ---- Property Lookup Timing ----
# Keep admin property lookups below proxy/browser timeout territory.
# Core property + satellite results still return when optional AI providers time out.
# PROPERTY_LOOKUP_TOTAL_BUDGET_MS=60000
# PROPERTY_LOOKUP_VISION_TIMEOUT_MS=25000
# PROPERTY_LOOKUP_VISION_MIN_REMAINING_MS=10000
# PROPERTY_LOOKUP_STORIES_MIN_REMAINING_MS=12000
# AI_PROPERTY_TIMEOUT_MS=30000
# AI_STORIES_TIMEOUT_MS=30000

# ---- Admin Phone (for escalation alerts) ----
ADAM_PHONE=+19413187612

# Owner-SMS kill switch.
# When set to 'true', server/services/twilio.js suppresses every SMS
# addressed to any of the operator's known phones (OWNER_PHONE,
# ADAM_PHONE, ADAM_CELL, WAVES_OFFICE_PHONE, WAVES_ADMIN_PHONE, plus
# the hardcoded fallbacks +19413187612 / +19415993489). Push
# notifications + bell entries continue normally — only Twilio sends
# are silenced. Reversible by unsetting or flipping to false.
# OWNER_SMS_DISABLED=true

# =============================================================================
# FEATURE GATES — Human-in-the-loop safety for production
#
# In production (NODE_ENV=production), ALL gates default to OFF.
# In development, all gates are ON by default.
#
# Deployment workflow:
#   1. Deploy to Railway with all gates OFF (don't set any GATE_ vars)
#   2. Check /api/health — confirms all gates show disabled
#   3. Test each integration manually via the admin portal
#   4. Enable gates one at a time in Railway environment variables
#
# =============================================================================
# GATE_TWILIO_SMS=true          # Real SMS to real phone numbers
# GATE_TWILIO_VOICE=true        # Voice call handling + recording
# GATE_AI_ASSISTANT=true        # AI auto-replies to customer SMS
# GATE_AI_BLOG_WRITER=true      # AI content generation
# GATE_CRON_JOBS=true           # All automated cron jobs
# GATE_WEBHOOKS=true            # Inbound Twilio/Stripe/Lead webhooks
# GATE_WORDPRESS_PUBLISH=true   # Publishing posts to WordPress
