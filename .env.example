# =============================================================================
# Waves Pest Control — Customer Portal Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================================

# ---- Server ----
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
CLIENT_URL=http://localhost:5173
WAVES_FDACS_LICENSE=JB351547
VITE_WAVES_FDACS_LICENSE=JB351547
# Google Maps JS API key for client-side address autocomplete. Required — there
# is no hardcoded fallback. Use a browser key restricted by HTTP referrer +
# Maps JavaScript/Places APIs in Google Cloud Console.
VITE_GOOGLE_MAPS_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://waves_user:your_password@localhost:5432/waves_portal
DB_POOL_MIN=2
DB_POOL_MAX=10

# ---- Authentication ----
JWT_SECRET=replace_with_random_64_char_string_use_openssl_rand_hex_32
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# ---- Twilio (SMS Notifications) ----
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+19415551234
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Stripe (Payments) ----
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ---- Stripe Terminal / Tap to Pay on iPhone ----
# Pre-registered Stripe Terminal location for the iOS Tap to Pay app.
STRIPE_TERMINAL_LOCATION_ID=tml_xxxxxxxxxxxxxx
# HMAC signing secret for short-lived (60s) handoff JWTs minted by
# POST /api/stripe/terminal/handoff. MUST be different from JWT_SECRET so
# that a portal-token leak does not let an attacker mint card_present
# tokens. Generate with: openssl rand -hex 32
TERMINAL_HANDOFF_SECRET=replace_with_openssl_rand_hex_32_output
# Per-tech mint ceiling per rolling hour. Baseline 20 assumes 8–12 normal
# stops/day + retry headroom; 20+ within an hour is alert-worthy. Dev can
# set 100 for easier manual testing. Leave blank to use the default (20).
HANDOFF_MINT_RATE_LIMIT_PER_HOUR=

# ---- Bouncie GPS / Mileage ----
BOUNCIE_CLIENT_ID=your_bouncie_client_id
BOUNCIE_CLIENT_SECRET=your_bouncie_client_secret
BOUNCIE_ACCESS_TOKEN=optional_bootstrap_access_token
BOUNCIE_REFRESH_TOKEN=optional_bootstrap_refresh_token
BOUNCIE_WEBHOOK_SECRET=replace_with_bouncie_webhook_key
BOUNCIE_VEHICLE_IMEI=optional_default_vehicle_imei
BOUNCIE_REDIRECT_URI=https://portal.example.com/api/bouncie/callback
# Optional static OAuth state for manual auth URLs. Prefer /api/bouncie/auth.
BOUNCIE_OAUTH_STATE=

# ---- AWS S3 (Service Photos) ----
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET=waves-pest-control-photos
S3_PHOTO_PREFIX=service-photos/

# ---- Rate Limiting ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- Logging ----
LOG_LEVEL=info

# ---- Anthropic (AI Assistant, Blog Writer, CSR Coach) ----
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ---- Google API (GSC, GBP) ----
GOOGLE_API_KEY=AIzaxxxxxxxx

# ---- Social Media Automation ----
# Global kill switch. Keep false until platform credentials and dry-run output are verified.
SOCIAL_AUTOMATION_ENABLED=false
SOCIAL_DRY_RUN=true
SOCIAL_FACEBOOK_ENABLED=false
SOCIAL_INSTAGRAM_ENABLED=false
SOCIAL_LINKEDIN_ENABLED=false
SOCIAL_GBP_ENABLED=false
SOCIAL_RSS_AUTOPUBLISH_ENABLED=false
# Deterministic per-post social share: when an AUTONOMOUS blog post is verified
# live (PR merged + deployed + 200), the PR poller shares it to social right then
# instead of waiting for the 4-hourly RSS poll to catch it. Same on/off as
# SOCIAL_RSS_AUTOPUBLISH_ENABLED (the RSS cron is the dedupe-safe backstop).
# Defaults ON; set false to fall back to RSS-only sharing without disabling RSS.
SOCIAL_BLOG_MERGE_SHARE_ENABLED=true
SOCIAL_SCHEDULED_POSTS_ENABLED=false
SOCIAL_NEWSLETTER_AUTOSHARE_ENABLED=false
FACEBOOK_PAGE_ID=
FACEBOOK_ACCESS_TOKEN=
INSTAGRAM_ACCOUNT_ID=
LINKEDIN_COMPANY_ID=
LINKEDIN_ACCESS_TOKEN=
SOCIAL_MEDIA_CDN_DOMAIN=

# Autonomous Social Studio.
# Set SOCIAL_DRY_RUN=false only when you want real posts to publish.
# SOCIAL_AUTONOMOUS_STUDIO_ENABLED turns the Studio on for manual admin use and
# gates its write endpoints. SOCIAL_AUTONOMOUS_CRON_ENABLED is the SEPARATE
# opt-in for the scheduler to publish automatically — both must be true for
# autonomous posts to run, so enabling manual use alone never auto-posts.
# The autonomous post fires once daily at 6:30 AM ET (scheduler.js). The
# interval is a < 24h cadence guard (dedupe), NOT the schedule — keep it under
# 24 so the fixed daily tick always clears it.
SOCIAL_AUTONOMOUS_STUDIO_ENABLED=false
SOCIAL_AUTONOMOUS_CRON_ENABLED=false
SOCIAL_AUTONOMOUS_MODE=publish
SOCIAL_AUTONOMOUS_INTERVAL_HOURS=20
# linkedin is NOT wired yet (publish path hard-disables it) — leave it out.
SOCIAL_AUTONOMOUS_CHANNELS=gbp,facebook,instagram
SOCIAL_AUTONOMOUS_INCLUDE_REVIEWS=true

# Social Creative Engine — AI photo scenes behind the deterministic brand layer.
# OFF by default: autonomous posts keep the legacy SVG brand card. When enabled,
# each autonomous run generates a photoreal scene (rotating per-service concept
# library, no-repeat vs recent runs) and composites the brand overlay on top;
# any provider/upload failure falls back to the SVG card, never a blocked post.
# Draft runs (SOCIAL_AUTONOMOUS_MODE=draft) generate SOCIAL_CREATIVE_VARIANTS
# options (1-4) into the Run Audit approval queue; publish runs generate one.
# SOCIAL_IMAGE_PROVIDER orders the image chain (default: image-native Gemini
# "Nano Banana" first, then gpt-image, then legacy gemini). Model IDs are
# env-overridable via MODEL_GEMINI_IMAGE / MODEL_GEMINI_IMAGE_STABLE.
SOCIAL_CREATIVE_ENGINE_ENABLED=false
SOCIAL_CREATIVE_VARIANTS=3
# SOCIAL_IMAGE_PROVIDER=gemini-image-best,gemini-image,gpt-image-2,gpt-image-1.5,gpt-image-1,gemini
# MODEL_GEMINI_IMAGE=gemini-3.1-flash-image-preview
# MODEL_GEMINI_IMAGE_STABLE=gemini-2.5-flash-image

# Social Video (Veo Reels) — separate opt-in ON TOP of the creative engine.
# Every SOCIAL_VIDEO_INTERVAL_DAYS-th ET day, a DRAFT campaign run also gets one
# 8s 9:16 Veo clip (~$1.20, Veo 3.1 Fast) as an extra approval-queue variant.
# Video never publishes without approval; approving a video posts it as an IG
# Reel + FB page video while GBP keeps the image variant. Veo failure just means
# no video option that day. Model IDs env-overridable (preview IDs get retired).
SOCIAL_VIDEO_ENABLED=false
SOCIAL_VIDEO_INTERVAL_DAYS=3
# MODEL_GEMINI_VIDEO=veo-3.1-fast-generate-preview
# MODEL_GEMINI_VIDEO_QUALITY=veo-3.1-generate-preview
# SOCIAL_VIDEO_TIMEOUT_MS=390000  # default 6.5min — Veo peak latency is documented up to 6min

# ---- Property Lookup Timing ----
# Keep admin property lookups below proxy/browser timeout territory.
# Core property + satellite results still return when optional AI providers time out.
# PROPERTY_LOOKUP_TOTAL_BUDGET_MS=60000
# PROPERTY_LOOKUP_VISION_TIMEOUT_MS=25000
# PROPERTY_LOOKUP_VISION_MIN_REMAINING_MS=10000
# PROPERTY_LOOKUP_STORIES_MIN_REMAINING_MS=12000
# AI_PROPERTY_TIMEOUT_MS=30000
# AI_STORIES_TIMEOUT_MS=30000

# ---- Admin Phone (for escalation alerts) ----
ADAM_PHONE=+19413187612

# Owner-SMS kill switch.
# When set to 'true', server/services/twilio.js suppresses every SMS
# addressed to any of the operator's known phones (OWNER_PHONE,
# ADAM_PHONE, ADAM_CELL, WAVES_OFFICE_PHONE, WAVES_ADMIN_PHONE, plus
# the hardcoded fallbacks +19413187612 / +19415993489). Push
# notifications + bell entries continue normally — only Twilio sends
# are silenced. Reversible by unsetting or flipping to false.
# OWNER_SMS_DISABLED=true

# =============================================================================
# FEATURE GATES — Human-in-the-loop safety for production
#
# In production (NODE_ENV=production), ALL gates default to OFF.
# In development, all gates are ON by default.
#
# Deployment workflow:
#   1. Deploy to Railway with all gates OFF (don't set any GATE_ vars)
#   2. Check /api/health — confirms all gates show disabled
#   3. Test each integration manually via the admin portal
#   4. Enable gates one at a time in Railway environment variables
#
# =============================================================================
# GATE_TWILIO_SMS=true          # Real SMS to real phone numbers
# GATE_TWILIO_VOICE=true        # Voice call handling + recording
# GATE_AI_ASSISTANT=true        # AI auto-replies to customer SMS
# GATE_ASK_WAVES=true           # Ask Waves conversational intake on the marketing site
# GATE_AI_BLOG_WRITER=true      # AI content generation
# GATE_CRON_JOBS=true           # All automated cron jobs
# GATE_WEBHOOKS=true            # Inbound Twilio/Stripe/Lead webhooks
# GATE_WORDPRESS_PUBLISH=true   # Publishing posts to WordPress
# GATE_LEAD_TURNSTILE=true      # Enforce Cloudflare Turnstile on POST /api/leads (bot spam guard)

# =============================================================================
# CLOUDFLARE TURNSTILE — public lead-form bot protection
#
# Server-side verification for the Turnstile widget(s) on the public lead forms.
# A widget caps at 10 hostnames (free tier) and the fleet is >10 registrable
# domains, so it takes MULTIPLE widgets. Turnstile tokens are single-use, so the
# server verifies each token with its OWNING widget's secret (chosen by the
# submitting domain) in exactly one call. TURNSTILE_SECRET_KEY is EITHER:
#   - a single secret string (one widget, matches every domain), OR
#   - a JSON array mapping each widget's secret to its registrable domains:
#     [{"secret":"0x..A","domains":["wavespestcontrol.com","parrishpestcontrol.com",...]},
#      {"secret":"0x..B","domains":["sarasotaflpestcontrol.com","waveslawncare.com",...]}]
#     (www/subdomains — incl. portal.wavespestcontrol.com — match by registrable
#     domain, so list the apex only.) Each widget also has its own PUBLIC site
#     key, shipped per-domain as PUBLIC_TURNSTILE_SITE_KEY (Astro) and
#     VITE_TURNSTILE_SITE_KEY (portal — the widget covering wavespestcontrol.com).
# Leave unset to fail OPEN (no verification, today's behavior). Enforcement also
# requires GATE_LEAD_TURNSTILE=true above.
# TURNSTILE_SECRET_KEY=
#
# Portal client (Vite) — the /quote wizard's Turnstile site key. PUBLIC, exposed
# to the browser; leave unset to render no widget (forms submit with no token).
# VITE_TURNSTILE_SITE_KEY=

# =============================================================================
# GOOGLE ADS — OFFLINE CONVERSIONS (Data Manager API)
#
# Uploads qualified leads + completed-job revenue back to Google Ads via the
# Data Manager API (server/services/ads/data-manager.js), so Smart Bidding
# optimises toward qualified leads + revenue. Auth is a service account with the
# datamanager scope (NOT the GOOGLE_ADS_* OAuth refresh token).
# GOOGLE_SERVICE_ACCOUNT_JSON=...                      # or GOOGLE_ADS_DATA_MANAGER_SERVICE_ACCOUNT_JSON
# GOOGLE_ADS_DATA_MANAGER_CUSTOMER_ID=3393936713       # operating account (falls back to GOOGLE_ADS_CUSTOMER_ID)
# GOOGLE_ADS_DM_QUALIFIED_LEAD_CONVERSION_ACTION_ID=<conversionActionId>
# GOOGLE_ADS_DM_COMPLETED_JOB_CONVERSION_ACTION_ID=<conversionActionId>
# GOOGLE_DATA_MANAGER_ALLOW_UPLOADS=true   # master: allow LIVE uploads (else validate-only)
# GOOGLE_DATA_MANAGER_VALIDATE_ONLY=false  # when false (and ALLOW_UPLOADS=true) uploads are real
# GOOGLE_DATA_MANAGER_CRON_ENABLED=true    # opt-in: run the daily 6:40am ET upload cron (manual admin endpoint works regardless)
#
# Google Customer Match (suppression + retargeting list upload via the SAME Data Manager
# service account + GOOGLE_ADS_DATA_MANAGER_CUSTOMER_ID above). The user lists must already
# exist in Google Ads (account must have accepted Customer Match terms); set their ids here.
# GOOGLE_CM_CUSTOMERS_LIST_ID=...          # Customer Match user-list id for the suppression audience
# GOOGLE_CM_UNBOOKED_LEADS_LIST_ID=...     # Customer Match user-list id for the unbooked-lead retargeting audience
# GOOGLE_CUSTOMER_MATCH_ALLOW_UPLOADS=true # master: allow LIVE audience writes (else dry-run delta only)
# GOOGLE_CUSTOMER_MATCH_CRON_ENABLED=true  # opt-in: run the daily 7:20am ET sync (manual admin endpoint works regardless)
# GOOGLE_CM_MAX_MEMBERS_PER_CALL=10000     # optional: members per Data Manager request (default/cap 10000)

# =============================================================================
# META (FACEBOOK/INSTAGRAM) ADS — ingestion + offline conversions (Conversions API)
#
# Ingestion (Phase 1): pulls Meta campaigns + daily insights into the PPC
# dashboard (platform='facebook'). Needs a Meta Marketing API System User token
# (ads_read scope) + the ad account id. No-ops until both are set.
# META_ADS_ACCESS_TOKEN=...                 # System User token, ads_read scope
# META_ADS_ACCOUNT_ID=act_1234567890        # ad account id (act_ prefix optional)
# META_ADS_API_VERSION=v23.0                # set to a CURRENTLY-SUPPORTED Graph API version (Meta deprecates ~yearly; default may be stale)
#
# Attribution (Phase 2): fbclid/fbc/fbp are captured automatically on web leads
# (no env needed) once deployed.
#
# Offline conversions / CAPI (Phase 3): uploads qualified-lead + revenue back to
# Meta's Conversions API. Needs a Pixel/Dataset id + a CAPI access token.
# META_CAPI_PIXEL_ID=...                    # Pixel (dataset) id
# META_CAPI_ACCESS_TOKEN=...                # Conversions API access token
# META_CAPI_TEST_EVENT_CODE=TEST12345       # optional: route to Test Events (no real attribution) for validation
# META_CAPI_ALLOW_UPLOADS=true              # master: allow LIVE CAPI uploads (else dry-run only)
# META_CAPI_CRON_ENABLED=true               # opt-in: run the daily upload cron (manual/validate works regardless)
#
# Meta Custom Audiences (suppression + retargeting list upload). SEPARATE from the
# read-only ingestion token: uploading a customer file needs an ads_management token
# + the ad account must have accepted Meta's Custom Audience Terms. Reuses META_ADS_ACCOUNT_ID.
# META_AUDIENCES_ACCESS_TOKEN=...           # ads_management token (NOT the read-only META_ADS_ACCESS_TOKEN)
# META_AUDIENCES_ALLOW_UPLOADS=true         # master: allow LIVE audience writes (else dry-run delta only)
# META_AUDIENCES_CRON_ENABLED=true          # opt-in: run the daily 7:10am ET audience sync
# META_AUDIENCES_API_VERSION=               # optional override (defaults to META_ADS_API_VERSION)

# ── AI call pipeline: booking + extraction ──────────────────────────────────
# Default technician auto-assigned to phone-call bookings. ID (UUID) wins over
# name; name match is exact (case/whitespace-insensitive). With neither set,
# falls back to the sole active technician when only one exists.
# CALL_BOOKING_DEFAULT_TECHNICIAN_ID=...
# CALL_BOOKING_DEFAULT_TECHNICIAN_NAME=Adam
#
# V2 structured call extraction. ENABLED runs it (shadow alongside V1);
# DRIVES_ROUTING promotes it to gate appointments (confidence threshold +
# triage flags -> Needs Review). See docs/call-extraction-hardening-runbook.md
# for the promotion-readiness queries before flipping DRIVES_ROUTING.
# CALL_EXTRACTION_V2_ENABLED=true
# CALL_EXTRACTION_V2_DRIVES_ROUTING=true
